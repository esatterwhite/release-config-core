{
  "name": "@codedependant/release-config-core",
  "version": "1.1.1",
  "description": "Baseline shareable semantic-release configuration for codedependant projects",
  "main": "index.js",
  "directories": {
    "lib": "lib"
  },
  "files": [
    "lib/",
    "index.js",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "npm run lint -- --fix",
    "test": "tap",
    "test:ci": "tap",
    "pretest": "npm run lint",
    "pretest:ci": "npm run lint",
    "release": "npx semantic-release",
    "release:dry": "npm run release -- --no-ci --dry-run --branches=${BRANCH_NAME:-main}"
  },
  "keywords": [
    "semantic-release",
    "semantic-release-config",
    "shareable-config",
    "codedependant"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/esatterwhite/release-config-core.git"
  },
  "author": "Eric Satterwhite <esatterwhite@wi.rr.com>",
  "bugs": {
    "url": "https://github.com/esatterwhite/release-config-core/issues"
  },
  "homepage": "https://github.com/esatterwhite/release-config-core#readme",
  "license": "MIT",
  "tap": {
    "browser": false,
    "show-full-coverage": true,
    "coverage-report": [
      "text",
      "text-summary",
      "json",
      "json-summary",
      "html"
    ],
    "plugin": [
      "!@tapjs/typescript"
    ],
    "output-file": ".tap-output",
    "files": [
      "test/unit"
    ]
  },
  "devDependencies": {
    "eslint": "^10.1.0",
    "eslint-config-logdna": "^8.0.1",
    "handlebars": "^4.7.7",
    "tap": "^21.7.1"
  },
  "overrides": {
    "lodash-es": "4.17.21"
  },
  "dependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1"
  }
}
